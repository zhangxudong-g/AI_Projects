# AutoCoder 环境配置示例
# 复制此文件为 .env 并填入实际值

# ============ 模型配置 ============

# 模型提供商：openai 或 ollama
MODEL_PROVIDER=ollama

# 模型名称
# OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Ollama: qwen2.5-coder:7b, llama2, codellama
# 可用模型 (http://133.238.28.90:51434):
#   - nemotron-3-super:120b (推荐，80.86GB)
#   - qwen3.5:122b-a10b (75.78GB)
#   - qwen3:32b (18.81GB)
#   - qwen2.5vl:32b (19.71GB)
#   - gpt-oss:20b (12.85GB)
#   - smollm2:135m (0.25GB, 最快)
MODEL_MODEL_NAME=nemotron-3-super:120b

# API 密钥（OpenAI 必需，Ollama 可选）
MODEL_API_KEY=

# API 基础 URL（可选）
# OpenAI: https://api.openai.com/v1
# Ollama: http://localhost:11434
# 其他兼容 OpenAI 格式的 API: 自定义 URL
MODEL_BASE_URL=http://133.238.28.90:51434

# 温度参数 (0.0 - 2.0)
MODEL_TEMPERATURE=0.7

# 最大 token 数
MODEL_MAX_TOKENS=4096

# ============ 执行配置 ============

# 最大循环次数（防止死循环）
EXEC_MAX_ITERATIONS=10

# 工作空间目录（生成的代码存放位置）
EXEC_WORKSPACE_DIR=workspace

# 命令执行超时（秒）
EXEC_TIMEOUT_SECONDS=60

# ============ 日志配置 ============

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 调试模式：true 或 false
LOG_DEBUG_MODE=false

# 日志文件路径（可选，不设置则只输出到控制台）
LOG_FILE=
