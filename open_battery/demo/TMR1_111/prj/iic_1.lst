 138   2            IIC1_SCL=1;
 139   2              dat<<=1;
 140   2              if(IIC1_SDA)dat++;   
 141   2          DelayUs(3); 
 142   2          }          
 143   1          IIC1_NAck();           //发送nACK
 144   1        
 145   1          return dat;
 146   1      }
