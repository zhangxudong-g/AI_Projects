 101           
 102          static void IIC1_Send_Byte(unsigned char txd)
 103          {
 104   1        unsigned char i;
 105   1        IIC1_SDA_Out();   //Set SDA Output 
 106   1          IIC1_SCL=0;            //拉低时钟开始数据传输
 107   1          for(i=0;i<8;i++)
 108   1          {              
 109   2          if(txd&0x80)
 110   2            IIC1_SDA=1;
 111   2          else
 112   2            IIC1_SDA=0;
 113   2          txd<<=1;    
 114   2          DelayUs(3);         
 115   2          IIC1_SCL=1;
