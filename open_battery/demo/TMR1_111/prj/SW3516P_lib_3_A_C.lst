 153          unsigned char SW3516p_Get_Port_State_3_A_C(void)
 154          {
 155   1              static unsigned char por = 0;
 156   1              unsigned int temp = 0;
 157   1              IIC_ADDRESS = 0X08;
 158   1          SW3516P_3_IIC_READ();
 159   1          IIC_DAT &= 0xF0;
 160   1          if(IIC_DAT == 0X60 || IIC_DAT == 0X80)         // 单C模式  表示C口开
 161   1          {
 162   2                      por |= 0x04;
 163   2          }else
 164   1          {
 165   2              por &= 0xFB;
 166   2          
 167   2          }
 168   1          IIC_ADDRESS = 0X3A;
 169   1          SW3516P_3_IIC_READ();
 170   1          IIC_DAT &= 0XF8;
 171   1          IIC_DAT |= 0X04;
 172   1          SW3516P_3_IIC_WRITE();
 173   1          
 174   1          IIC_ADDRESS = 0X3B;
 175   1          SW3516P_3_IIC_READ();  // 2.5mA/bit
 176   1          temp = IIC_DAT << 4;
 177   1          IIC_ADDRESS = 0X3C;
C51 COMPILER V9.59.0.0   SW3516P_LIB_3_A_C                                                 11/12/2025 15:54:08 PAGE 4   

 178   1          SW3516P_3_IIC_READ();
 179   1          temp |= (IIC_DAT & 0x0F);
 180   1          temp *= 2.5;
 181   1          if(temp > 80)
 182   1          {
 183   2              por |= 0x08;
 184   2          }else if(temp < 15)
 185   1          {
 186   2              por &= 0xF7;
 187   2          }
 188   1              return por;
 189   1      }
